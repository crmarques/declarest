COMPONENT_TYPE=git-provider
COMPONENT_NAME=gitlab
COMPONENT_CONTRACT_VERSION=1
SUPPORTED_CONNECTIONS="local remote"
DEFAULT_CONNECTION=local
REQUIRES_DOCKER=true
COMPONENT_RUNTIME_KIND=compose
COMPONENT_DEPENDS_ON=""
COMPONENT_SERVICE_PORT=80
REPOSITORY_WEBHOOK_PROVIDER=gitlab
REPO_PROVIDER_LOGIN_PATH="/users/sign_in"
DESCRIPTION="GitLab provider (local container or remote instance)"
