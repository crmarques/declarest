COMPONENT_TYPE=git-provider
COMPONENT_NAME=gitea
COMPONENT_CONTRACT_VERSION=1
SUPPORTED_CONNECTIONS="local remote"
DEFAULT_CONNECTION=local
DEFAULT_SELECTIONS="operator"
REQUIRES_DOCKER=true
COMPONENT_RUNTIME_KIND=compose
COMPONENT_DEPENDS_ON=""
COMPONENT_SERVICE_PORT=3000
REPOSITORY_WEBHOOK_PROVIDER=gitea
REPO_PROVIDER_LOGIN_PATH="/user/login"
DESCRIPTION="Gitea provider (local container or remote instance)"
