COMPONENT_TYPE=managed-service
COMPONENT_NAME=simple-api-server
COMPONENT_CONTRACT_VERSION=1
SUPPORTED_CONNECTIONS="local remote"
DEFAULT_CONNECTION=local
DEFAULT_SELECTIONS="base operator"
REQUIRES_DOCKER=true
COMPONENT_RUNTIME_KIND=compose
COMPONENT_DEPENDS_ON=""
COMPONENT_SERVICE_PORT=8080
SUPPORTED_SECURITY_FEATURES="none basic-auth oauth2 mtls"
OPERATOR_EXAMPLE_RESOURCE_PATH="/api/projects/operator-demo"
OPERATOR_EXAMPLE_RESOURCE_PAYLOAD='{"id":"operator-demo","name":"operator-demo","displayName":"Operator Demo","owner":"operator-e2e"}'
DESCRIPTION="Simple JSON API with toggleable basic-auth/oauth2 and optional mTLS client-cert enforcement"
