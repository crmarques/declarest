COMPONENT_TYPE=managed-service
COMPONENT_NAME=haproxy
COMPONENT_CONTRACT_VERSION=1
SUPPORTED_CONNECTIONS="local remote"
DEFAULT_CONNECTION=local
REQUIRES_DOCKER=true
COMPONENT_RUNTIME_KIND=compose
COMPONENT_DEPENDS_ON=""
COMPONENT_SERVICE_PORT=5555
SUPPORTED_SECURITY_FEATURES="basic-auth"
REQUIRED_SECURITY_FEATURES="basic-auth"
METADATA_BUNDLE_REF="haproxy-bundle:0.0.1"
OPERATOR_EXAMPLE_RESOURCE_PATH="/sites/operator-demo"
OPERATOR_EXAMPLE_RESOURCE_PAYLOAD='{"name":"operator-demo","services":[]}'
DESCRIPTION="HAProxy Data Plane API managed service"
