COMPONENT_TYPE=managed-service
COMPONENT_NAME=rundeck
COMPONENT_CONTRACT_VERSION=1
SUPPORTED_CONNECTIONS="local remote"
DEFAULT_CONNECTION=local
REQUIRES_DOCKER=true
COMPONENT_RUNTIME_KIND=compose
COMPONENT_DEPENDS_ON=""
COMPONENT_SERVICE_PORT=4440
SUPPORTED_SECURITY_FEATURES="basic-auth custom-header"
METADATA_BUNDLE_REF="oci://ghcr.io/crmarques/declarest-metadata-bundles/rundeck:0.0.1"
OPERATOR_EXAMPLE_RESOURCE_PATH="/project/operator-demo"
OPERATOR_EXAMPLE_RESOURCE_PAYLOAD='{"name":"operator-demo","description":"Operator Demo Project"}'
DESCRIPTION="Rundeck HTTP API managed service"
