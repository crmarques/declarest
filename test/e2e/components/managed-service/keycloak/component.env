COMPONENT_TYPE=managed-service
COMPONENT_NAME=keycloak
COMPONENT_CONTRACT_VERSION=1
SUPPORTED_CONNECTIONS="local remote"
DEFAULT_CONNECTION=local
REQUIRES_DOCKER=true
COMPONENT_RUNTIME_KIND=compose
COMPONENT_DEPENDS_ON=""
COMPONENT_SERVICE_PORT=8080
SUPPORTED_SECURITY_FEATURES="oauth2"
REQUIRED_SECURITY_FEATURES="oauth2"
METADATA_BUNDLE_REF="oci://ghcr.io/crmarques/declarest-metadata-bundles/keycloak:0.0.1"
OPERATOR_EXAMPLE_RESOURCE_PATH="/admin/realms/operator-demo"
OPERATOR_EXAMPLE_RESOURCE_PAYLOAD='{"realm":"operator-demo","enabled":true,"displayName":"Operator Demo Realm"}'
DESCRIPTION="Keycloak Admin REST API with OAuth2 client-credentials auth"
