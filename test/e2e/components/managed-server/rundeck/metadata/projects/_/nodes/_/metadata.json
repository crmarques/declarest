{
  "resourceInfo": {
    "idFromAttribute": "/index",
    "aliasFromAttribute": "/index",
    "collectionPath": "/projects/{{.project}}/nodes"
  },
  "operationsInfo": {
    "createResource": {
      "httpMethod": "POST",
      "path": "/project/{{.project}}/source/{{.id}}/resources"
    },
    "getResource": {
      "path": "/project/{{.project}}/source/{{.id}}/resources"
    },
    "updateResource": {
      "httpMethod": "POST",
      "path": "/project/{{.project}}/source/{{.id}}/resources"
    },
    "listCollection": {
      "path": "/project/{{.project}}/sources",
      "payloadMutation": [
        {
          "jqExpression": "map(. + {index: (.index | tostring), project: \"{{.project}}\"})"
        }
      ]
    },
    "compareResources": {
      "path": "/project/{{.project}}/source/{{.id}}/resources"
    }
  }
}
