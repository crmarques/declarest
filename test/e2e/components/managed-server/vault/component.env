COMPONENT_TYPE=managed-server
COMPONENT_NAME=vault
COMPONENT_CONTRACT_VERSION=1
SUPPORTED_CONNECTIONS="local remote"
DEFAULT_CONNECTION=local
REQUIRES_DOCKER=true
COMPONENT_RUNTIME_KIND=compose
COMPONENT_DEPENDS_ON=""
COMPONENT_SERVICE_PORT=8200
SUPPORTED_SECURITY_FEATURES="custom-header"
OPERATOR_EXAMPLE_RESOURCE_PATH="/v1/secret/data/declarest/operator-demo"
OPERATOR_EXAMPLE_RESOURCE_PAYLOAD='{"path":"declarest/operator-demo","data":{"token":"operator-demo-token","owner":"operator-e2e"}}'
DESCRIPTION="HashiCorp Vault HTTP API as managed server"
