{
  "idFromAttribute": "path",
  "aliasFromAttribute": "path",
  "operations": {
    "create": {
      "path": "/v1/secret/data/{{.path}}"
    },
    "get": {
      "path": "/v1/secret/data/{{.path}}"
    },
    "update": {
      "method": "POST",
      "path": "/v1/secret/data/{{.path}}"
    },
    "delete": {
      "path": "/v1/secret/metadata/{{.path}}"
    },
    "list": {
      "path": "/v1/secret/metadata/declarest",
      "query": {
        "list": "true"
      }
    },
    "compare": {
      "path": "/v1/secret/data/{{.path}}"
    }
  }
}
