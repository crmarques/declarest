{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeclaREST Resource Metadata",
  "description": "Canonical nested metadata wire schema. Legacy flat aliases are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "selector": {
      "$ref": "#/$defs/selector"
    },
    "resource": {
      "$ref": "#/$defs/resource"
    },
    "operations": {
      "$ref": "#/$defs/operations"
    }
  },
  "$defs": {
    "jsonPointer": {
      "type": "string",
      "pattern": "^/.*$",
      "description": "RFC 6901 JSON Pointer."
    },
    "jsonPointerArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonPointer"
      }
    },
    "jsonPointerOrArray": {
      "oneOf": [
        {
          "$ref": "#/$defs/jsonPointer"
        },
        {
          "$ref": "#/$defs/jsonPointerArray"
        }
      ]
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "stringMapOrEntryList": {
      "oneOf": [
        {
          "$ref": "#/$defs/stringMap"
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      ]
    },
    "resourceFormat": {
      "type": "string",
      "enum": [
        "json",
        "yaml",
        "xml",
        "hcl",
        "ini",
        "properties",
        "text",
        "octet-stream",
        "any"
      ]
    },
    "defaultsMode": {
      "type": "string",
      "enum": [
        "inherit",
        "ignore",
        "replace"
      ]
    },
    "defaultsIncludeValue": {
      "type": "string",
      "pattern": "^\\{\\{include defaults(?:-[A-Za-z0-9][A-Za-z0-9._-]*)?\\.(?:yaml|yml|json|properties)\\}\\}$"
    },
    "defaultsEntry": {
      "oneOf": [
        {
          "type": "object"
        },
        {
          "$ref": "#/$defs/defaultsIncludeValue"
        }
      ]
    },
    "defaultsProfiles": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/defaultsEntry"
      }
    },
    "defaultsSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/defaultsMode"
        },
        "useProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          }
        },
        "value": {
          "$ref": "#/$defs/defaultsEntry"
        },
        "profiles": {
          "$ref": "#/$defs/defaultsProfiles"
        }
      }
    },
    "identityTemplate": {
      "type": "string",
      "description": "Identity template string using canonical JSON Pointer placeholders such as {{/id}}, one-level shorthand such as {{id}}, or raw JSON Pointer shorthand such as /id."
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "descendants": {
          "type": "boolean"
        }
      }
    },
    "validationAssertion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "message": {
          "type": "string"
        },
        "jq": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "jq"
      ]
    },
    "operationValidation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiredAttributes": {
          "$ref": "#/$defs/jsonPointerOrArray"
        },
        "assertions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validationAssertion"
          }
        },
        "schemaRef": {
          "type": "string",
          "pattern": "^(openapi:request-body|openapi:#/.+)$"
        }
      }
    },
    "transformStep": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selectAttributes": {
          "$ref": "#/$defs/jsonPointerOrArray"
        },
        "excludeAttributes": {
          "$ref": "#/$defs/jsonPointerOrArray"
        },
        "jqExpression": {
          "type": "string"
        }
      },
      "oneOf": [
        {
          "required": [
            "selectAttributes"
          ]
        },
        {
          "required": [
            "excludeAttributes"
          ]
        },
        {
          "required": [
            "jqExpression"
          ]
        }
      ]
    },
    "externalizedAttribute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/jsonPointer"
        },
        "file": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!\\.?$)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "template": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "text"
          ]
        },
        "saveBehavior": {
          "type": "string",
          "enum": [
            "externalize"
          ]
        },
        "renderBehavior": {
          "type": "string",
          "enum": [
            "include"
          ]
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "path",
        "file"
      ]
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "allOf": [
            {
              "$ref": "#/$defs/identityTemplate"
            }
          ],
          "default": "/id"
        },
        "alias": {
          "allOf": [
            {
              "$ref": "#/$defs/identityTemplate"
            }
          ],
          "default": "/id"
        },
        "requiredAttributes": {
          "$ref": "#/$defs/jsonPointerArray"
        },
        "remoteCollectionPath": {
          "type": "string",
          "description": "Template string that can render metadata scope attributes using canonical JSON Pointer placeholders such as {{/realm}} or one-level shorthand such as {{realm}}."
        },
        "format": {
          "$ref": "#/$defs/resourceFormat"
        },
        "defaults": {
          "$ref": "#/$defs/defaultsSpec"
        },
        "secret": {
          "type": "boolean"
        },
        "secretAttributes": {
          "$ref": "#/$defs/jsonPointerArray"
        },
        "externalizedAttributes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/externalizedAttribute"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "secret": {
                "const": true
              }
            },
            "required": [
              "secret"
            ]
          },
          "then": {
            "not": {
              "properties": {
                "secretAttributes": {
                  "minItems": 1
                }
              },
              "required": [
                "secretAttributes"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "format": {
                "enum": [
                  "xml",
                  "hcl",
                  "text",
                  "octet-stream"
                ]
              }
            },
            "required": [
              "format"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "id"
                  ]
                },
                {
                  "required": [
                    "alias"
                  ]
                },
                {
                  "properties": {
                    "requiredAttributes": {
                      "minItems": 1
                    }
                  },
                  "required": [
                    "requiredAttributes"
                  ]
                },
                {
                  "properties": {
                    "secretAttributes": {
                      "minItems": 1
                    }
                  },
                  "required": [
                    "secretAttributes"
                  ]
                },
                {
                  "properties": {
                    "externalizedAttributes": {
                      "minItems": 1
                    }
                  },
                  "required": [
                    "externalizedAttributes"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "description": "Template string that can render metadata scope attributes using canonical JSON Pointer placeholders such as {{/id}} or one-level shorthand such as {{id}}."
        },
        "query": {
          "$ref": "#/$defs/stringMap"
        },
        "headers": {
          "$ref": "#/$defs/stringMapOrEntryList"
        },
        "body": true,
        "transforms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transformStep"
          }
        },
        "validate": {
          "$ref": "#/$defs/operationValidation"
        }
      }
    },
    "operationDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transforms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transformStep"
          }
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaults": {
          "$ref": "#/$defs/operationDefaults"
        },
        "get": {
          "$ref": "#/$defs/operation"
        },
        "create": {
          "$ref": "#/$defs/operation"
        },
        "update": {
          "$ref": "#/$defs/operation"
        },
        "delete": {
          "$ref": "#/$defs/operation"
        },
        "list": {
          "$ref": "#/$defs/operation"
        },
        "compare": {
          "$ref": "#/$defs/operation"
        }
      }
    }
  }
}
