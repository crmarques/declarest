{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeclaREST Context Catalog",
  "description": "Canonical persisted context catalog schema.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "contexts": {
      "type": "array",
      "items": {
        "$ref": "./context.schema.json"
      }
    },
    "currentContext": {
      "type": "string"
    },
    "defaultEditor": {
      "type": "string",
      "minLength": 1
    },
    "credentials": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/credential"
      }
    }
  },
  "required": [
    "contexts",
    "currentContext"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "contexts": {
            "minItems": 1
          }
        }
      },
      "then": {
        "properties": {
          "currentContext": {
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "contexts": {
            "maxItems": 0
          }
        }
      },
      "then": {
        "properties": {
          "currentContext": {
            "maxLength": 0
          }
        }
      }
    }
  ],
  "$defs": {
    "credentialPrompt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt": {
          "const": true
        },
        "persistInSession": {
          "type": "boolean"
        }
      },
      "required": [
        "prompt"
      ]
    },
    "credentialValue": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/credentialPrompt"
        }
      ]
    },
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "username": {
          "$ref": "#/$defs/credentialValue"
        },
        "password": {
          "$ref": "#/$defs/credentialValue"
        }
      },
      "required": [
        "name",
        "username",
        "password"
      ]
    }
  }
}
